# Cloudflare Pages headers
# Applies to every response unless overridden by a more specific rule below.
#
# IMPORTANT: Cloudflare Pages MERGES every matching rule's headers - it does NOT
# let a more specific rule override a broader one. So Cache-Control must NEVER be
# set on /* : it would concatenate onto every asset rule below
# ("max-age=0, must-revalidate, ... max-age=31536000, immutable") and browsers
# take the FIRST max-age, killing immutable caching and re-validating every asset
# on every navigation. Cache-Control is therefore scoped to explicit paths only.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block

# Long-cache immutable assets (filenames are versioned via ?v= query, content-hashed dir, or unique paths)
/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS bumped via ?v= query parameter - safe to cache aggressively
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/favicon.png
  Cache-Control: public, max-age=2592000

# HTML surfaces - stable URLs, change on every deploy, so never long-cache them.
# max-age=0 + must-revalidate = a deploy is live on the next navigation (cheap ETag
# 304), with no manual cache purge. Clean URLs (/about etc.) are extensionless, so
# they do NOT match /*.html and must be listed explicitly. ADD NEW PAGES HERE.
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/about
  Cache-Control: public, max-age=0, must-revalidate

/forma-architects
  Cache-Control: public, max-age=0, must-revalidate

/birse
  Cache-Control: public, max-age=0, must-revalidate

/404
  Cache-Control: public, max-age=0, must-revalidate

# SEO/AI files - short cache so updates ship quickly
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
